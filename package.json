{
  "name": "express-hbs-compile",
  "version": "1.0.2",
  "description": "Compile Handlebars templates into HTML strings, powered by express-hbs.",
  "main": "dist/build.common.js",
  "module": "dist/build.esm.js",
  "types": "types/index.d.ts",
  "files": [
    "dist/*.js",
    "types",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "watch": "rollup -c rollup.config.js --watch",
    "prewatch": "rimraf dist types",
    "build": "rollup -c rollup.config.js",
    "prebuild": "rimraf dist types",
    "test": "jest",
    "test:clear-cache": "jest --clearCache"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shumatsumonobu/express-hbs-compile.git"
  },
  "keywords": [
    "handlebars",
    "hbs",
    "template",
    "compile",
    "html",
    "express",
    "express-hbs",
    "layout",
    "partials",
    "helpers"
  ],
  "author": "shumatsumonobu <shumatsumonobu@gmail.com> (https://x.com/shumatsumonobu)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shumatsumonobu/express-hbs-compile/issues",
    "email": "shumatsumonobu@gmail.com"
  },
  "homepage": "https://github.com/shumatsumonobu/express-hbs-compile#readme",
  "dependencies": {
    "express-hbs": "^2.5.0",
    "handlebars": "^4.7.8",
    "handlebars-extd": "^1.0.14"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.2.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.3"
  }
}